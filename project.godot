; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="My-GFramework-Godot-Template"
config/tags=PackedStringArray("gamelab")
run/main_scene="uid://6s2urcdmkpbt"
config/features=PackedStringArray("4.6", "C#", "GL Compatibility")
config/save/setting_path="user://"
config/save/save_path="user://saves"
config/save/save_slot_prefix="slot_"
config/save/save_file_name="save.json"

[audio]

buses/default_bus_layout="res://resource/bus/project_bus_layout.tres"

[autoload]

GameEntryPoint="*res://global/game_entry_point.tscn"
SceneRoot="*uid://bxquqjahyr8v2"
UiRoot="*res://global/ui_root.tscn"
GlobalInputController="*res://global/GlobalInputController.cs"
SceneTransitionManager="*uid://c5sxf7tcun6yq"

[display]

window/size/viewport_width=960
window/size/viewport_height=540
window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="My-GFramework-Godot-Template"

[editor_plugins]

enabled=PackedStringArray()

[file_customization]

folder_colors={
"res://assets/": "red",
"res://global/": "orange",
"res://resource/": "yellow",
"res://scenes/": "green",
"res://script_templates/": "blue",
"res://scripts/": "teal"
}

